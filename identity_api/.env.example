# carbo-identity environment (copy to .env on the server)

# PostgreSQL for the identity database (its OWN database, separate from maintenance/quality)
DATABASE_URL=postgresql://carbo_identity@/carbo_identity?host=/var/run/postgresql

# Secret pepper mixed into password + token hashes. CHANGE THIS and keep it secret.
IDENTITY_SECRET_PEPPER=change-me-to-a-long-random-string

# Session token lifetime in hours
SESSION_TTL_HOURS=12

# Bootstrap admin (used only by seed_identity.py the first time).
# If password is blank, a random one is generated and printed once.
BOOTSTRAP_ADMIN_LOGIN=admin
BOOTSTRAP_ADMIN_PASSWORD=

# carbo-identity environment (copy to .env on the server)

# PostgreSQL — own database carbo_identity (NOT maintenance).
# Big-K: peer auth as bkweb3dev (same pattern as maintenance API).
DATABASE_URL=postgresql://bkweb3dev@/carbo_identity?host=/var/run/postgresql

# Secret pepper mixed into password + token hashes. REQUIRED — generate once, keep secret.
# On server: python3 -c "import secrets;print(secrets.token_urlsafe(48))"
IDENTITY_SECRET_PEPPER=change-me-to-a-long-random-string

SESSION_TTL_HOURS=12

# Bootstrap admin (seed_identity.py, first run only).
BOOTSTRAP_ADMIN_LOGIN=admin
BOOTSTRAP_ADMIN_PASSWORD=
